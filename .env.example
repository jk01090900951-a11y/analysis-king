# 이 파일을 복사해서 .env로 만들고 실제 값을 채우세요
# (.env는 .gitignore에 등록되어 있어 GitHub에 올라가지 않습니다)

DATABASE_URL=mysql://user:password@localhost:3306/analysis_king
PORT=3000
NODE_ENV=development

# API-Sports.io (이미 발급받으신 키)
API_SPORTS_KEY=

# Claude (Anthropic) - AI 분석글 생성용. console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=

# 세션 암호화용 (아무 랜덤 문자열이나 넣으세요)
JWT_SECRET=

# 최초 관리자 계정 부트스트랩 (아이디/비밀번호) — 서버 최초 기동 시 관리자 계정이 하나도 없으면
# 이 값으로 자동 생성됩니다. 최초 로그인 후에는 이 두 줄을 지우거나 그대로 둬도 무방합니다
# (계정이 이미 있으면 재실행되지 않습니다). 비밀번호는 8자 이상 권장.
ADMIN_USERNAME=
ADMIN_PASSWORD=
