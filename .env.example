# 이 파일을 복사해서 .env로 만들고 실제 값을 채우세요
# (.env는 .gitignore에 등록되어 있어 GitHub에 올라가지 않습니다)

DATABASE_URL=mysql://user:password@localhost:3306/analysis_king
PORT=3000
NODE_ENV=development

# API-Sports.io (이미 발급받으신 키)
API_SPORTS_KEY=

# OpenAI (AI 분석글 생성용)
OPENAI_API_KEY=

# 카카오 로그인 (developers.kakao.com에서 발급)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback

# 세션 암호화용 (아무 랜덤 문자열이나 넣으세요)
JWT_SECRET=

# 최초 관리자 계정 부트스트랩 — 카카오로 처음 로그인한 뒤 서버 로그에서 본인 openId(kakao_숫자) 확인 후 채워넣으면
# 다음 로그인부터 자동으로 관리자 권한이 부여됩니다.
OWNER_OPEN_ID=
